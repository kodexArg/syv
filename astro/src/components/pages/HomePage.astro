      <a href={docsUrl('atlas', 'ciudades/darsena/darsena')} class="px-4 py-2 rounded bg-olive-600 text-white no-underline hover:bg-olive-700 text-center">Ciudad Dársena</a>
      <a href={docsUrl('personajes', 'personajes')} class="px-4 py-2 rounded bg-olive-600 text-white no-underline hover:bg-olive-700 text-center">Personajes Principales</a>
